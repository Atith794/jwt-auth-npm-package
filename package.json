    "jwt authentication"
  ],
  "author": "Atith",
  "license": "MIT",
  "dependencies": {
    "@atith/jwt-auth-kit": "^1.0.0",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
